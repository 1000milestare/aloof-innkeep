# Google Calendar Configuration
# Can be a file path OR inline JSON (for CI/CD, set the full JSON as the value)
GOOGLE_SERVICE_ACCOUNT_JSON=./google_service_account.json
GOOGLE_CALENDAR_ID=foo@bar.baz

# Airbnb Configuration
AIRBNB_ICS_URL=https://www.airbnb.com/calendar/ical/foo.ics?bar=baz

# Logging
LOG_FILE=./airbnb-sync.log
LOG_LEVEL=debug

# Booking Times (24-hour format, used as defaults)
CHECKIN_TIME=15:00
CHECKOUT_TIME=10:00

# Seam Smart Lock Configuration (optional)
# Get these from: https://console.getseam.com
# Leave blank or comment out to disable smart lock integration
SEAM_API_KEY=
SEAM_DEVICE_ID=

# Gmail Configuration (optional — for per-reservation check-in/checkout times)
# Run `aloof-innkeep auth-gmail` to get the refresh token
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
